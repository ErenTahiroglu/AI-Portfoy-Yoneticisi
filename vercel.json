{
  "version": 2,
  "builds": [
    {
      "src": "src/frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ai-portfoy-yoneticisi.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/src/frontend/$1"
    }
  ]
}