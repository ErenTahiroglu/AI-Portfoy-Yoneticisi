# ═══════════════════════════════════════════════════
# Portföy Analiz Platformu — .gitignore
# ═══════════════════════════════════════════════════

# Environments & Keys
.env
.env.local
api_keys.json
.venv/
env/
venv/
ENV/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python Cache & Build
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
*.spec
*.pyc

# IDE and Editor files
.vscode/
.idea/
.pyre_configuration
*.code-workspace
*.swp
*.swo

# User Output / Reports (Generated files)
*.xlsx
*.csv
*.docx
*.pdf
results/
reports/

# Logs & Debug
*.log
error.txt
traceback.txt
tefas_log.txt

# Large Data & Binary
playwright-browsers/
backend/data/*.json
!backend/data/market_metadata.json
py-yfinance/

# Platform & Deployment
.DS_Store
Thumbs.db
desktop.ini
.vercel/
.gemini/
.agents/
.agent/

# Test Scripts & Temporary
/test_*.py
/test_*.json
.pytest_cache/
htmlcov/
find_api.py
*remote.py
fintables.html
Full_File_List.txt
test_output.txt

# Debug & Scratch files
debug_*.py
*debug*.py
out.txt

# Database files
*.db
*.sqlite3

# Puppeteer & Automated Testing
.cache/
/tests/ui/screenshots/*.png
!/tests/ui/screenshots/.gitkeep
