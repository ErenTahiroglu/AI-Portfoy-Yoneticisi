# 📊 Portföy Analiz Platformu — Environment Variables
# ===================================================

# 🌐 App Config
APP_NAME="Portfolio Analysis Platform"
ENVIRONMENT="production"  # development | production

# 🔑 API Keys
ALPHA_VANTAGE_KEY="your_alpha_vantage_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"

# 🛡️ Network & Security
SSL_VERIFY=True
REQUEST_TIMEOUT=15
GEMINI_TIMEOUT=30

# 🧠 Cache
CACHE_TTL_SECONDS=300

# ⚖️ Rate Limiting
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=1.5
