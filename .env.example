# 🤖 Generative AI (Google)
GEMINI_API_KEY=
GROQ_API_KEY=

# 📊 Financial Market Data APIs
POLYGON_API_KEY=
ALPHA_VANTAGE_KEY=
FRED_API_KEY=

# 🗄️ Supabase Configuration (Bağlantı & JWT)
SUPABASE_URL=
SUPABASE_KEY=

SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# 🔐 Security & Access (Temporary Setup)
# Legacy JWT secret (still used)
# Service_role secret: 604800 saniye (7 gün) max süre ayarlandı.
TEMP_ADMIN_PASSWORD=

# 💳 Billing / Webhooks
BILLING_WEBHOOK_SECRET=

# 🚀 Redis (Upstash) Cache Configuration
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 🌐 API & Environment Setup
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PYTHON_VERSION=3.12.0
SCHEDULER_INTERVAL_SECONDS=840

# 🤖 Sentinel / Healthcheck
WEBHOOK_URL=

# 📊 Extra Logs / Analytics
LOG_LEVEL=INFO
ENABLE_TELEMETRY=true
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc_dir
