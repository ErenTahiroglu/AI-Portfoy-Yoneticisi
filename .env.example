# 🛡️ AI-Portföy-Yöneticisi Environment Variables Template
# Bu dosyayı .env adıyla kopyalayın ve anahtarları doldurun.

# 🌟 Supabase (Database & Auth)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# 🤖 AI Providers (Multi-Agent Engine)
# Gemini (P1)
GOOGLE_API_KEY=your_gemini_api_key
# Groq (P2 - Llama/Mixtral)
GROQ_API_KEY=your_groq_api_key

# 🔴 Upstash Redis (Cache & Rate Limiting)
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# 🏛️ Financial APIs
# Alpha Vantage (Global Stock/FX)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
# Polygon (Alternative)
POLYGON_API_KEY=your_polygon_key

# 🧪 SRE & Testing
# CI ortamında dış ağ kalkanı (Network Block) için izin verilen hostlar
PYTEST_SOCKET_ALLOW_HOSTS=127.0.0.1,localhost
# Gözlemlenebilirlik (Observability)
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc_dir

# ⚙️ Application Settings
ENV=development # production / development
LOG_LEVEL=INFO
PORT=8000
