{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "HTMLElement": "readonly",
    "customElements": "readonly",
    "shadowRoot": "readonly",
    "marked": "readonly",
    "AppState": "readonly",
    "Chart": "readonly",
    "t": "readonly",
    "getLang": "readonly",
    "fmtNum": "readonly",
    "colorClass": "readonly",
    "openMetricModal": "readonly",
    "createTVChart": "readonly",
    "createRadarChart": "readonly",
    "createGaugeChart": "readonly",
    "renderScenarios": "readonly",
    "renderExtras": "readonly",
    "renderOptimization": "readonly",
    "runAnalysis": "readonly",
    "initTheme": "readonly",
    "toggleTheme": "readonly",
    "loadApiKeys": "readonly",
    "saveApiKeys": "readonly",
    "showToast": "readonly",
    "initOnboardingWizard": "readonly",
    "getUserProfile": "readonly",
    "currentLang": "readonly",
    "setLanguage": "readonly",
    "checkServerHealth": "readonly",
    "createEquityCurveChart": "readonly",
    "setupAutocomplete": "readonly",
    "setupSupabaseAuth": "readonly",
    "createStore": "readonly",
    "XLSX": "readonly",
    "html2canvas": "readonly",
    "decryptApiKey": "readonly",
    "encryptApiKey": "readonly",
    "API_BASE": "readonly",
    "IS_LOCAL": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "warn",
    "no-empty": "warn",
    "no-constant-condition": "warn",
    "no-console": "off",
    "no-inner-declarations": "off"
  },
  "plugins": [
    "html"
  ]
}
