[run]
branch = True
source = backend
omit = 
    backend/tests/*
    backend/migrations/*
    backend/alembic/*

[report]
show_missing = True
skip_covered = True
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
